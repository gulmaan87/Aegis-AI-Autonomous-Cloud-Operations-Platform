# Required — generate with: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_in_production
JWT_SECRET=change_me_generate_with_openssl_rand_base64_32

# Alertmanager webhook shared secret — generate with: openssl rand -base64 32
ALERT_WEBHOOK_SECRET=change_me_generate_with_openssl_rand_base64_32

# Azure OpenAI (Level 4 — AI Incident Commander)
# Leave blank to use mock/demo mode — no Azure account needed for local dev
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Optional
GRAFANA_PASSWORD=admin
NODE_ENV=production
FRONTEND_URL=http://localhost:3000
