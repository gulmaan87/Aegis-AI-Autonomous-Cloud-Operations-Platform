// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  hashedPassword String
  name           String?
  role           Role     @default(USER)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  experiments ChaosExperiment[]

  @@index([email])
}

model ChaosExperiment {
  id         String           @id @default(cuid())
  name       String
  type       ExperimentType
  durationMs Int
  status     ExperimentStatus @default(PENDING)
  startedAt  DateTime?
  endedAt    DateTime?
  stoppedBy  String?          // userId of whoever called /stop — null if auto-completed
  createdBy  String
  creator    User             @relation(fields: [createdBy], references: [id])
  createdAt  DateTime         @default(now())
  incident   Incident?

  @@index([status])
}

model Incident {
  id           String           @id @default(cuid())
  title        String
  severity     Severity         @default(MEDIUM)
  status       IncidentStatus   @default(OPEN)
  notes        String?
  alertName    String?
  fingerprint  String?          @unique
  source       IncidentSource   @default(CHAOS)
  experimentId String?          @unique
  experiment   ChaosExperiment? @relation(fields: [experimentId], references: [id])
  aiAnalysis   AiAnalysis?
  resolvedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([status])
  @@index([fingerprint])
}

model AiAnalysis {
  id               String   @id @default(cuid())
  incidentId       String   @unique
  incident         Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  rootCause        String
  impact           String
  remediationSteps String   // JSON-encoded string[]
  riskScore        Severity
  confidence       Int      // 0–100
  model            String   // e.g. "gpt-4o" or "mock"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
  OPERATOR
}

enum ExperimentType {
  HIGH_CPU
  HIGH_LATENCY
  SERVICE_ERROR
  DB_SLOWDOWN
  MEMORY_PRESSURE
}

enum ExperimentStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  STOPPED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
}

enum IncidentSource {
  CHAOS  // created by a chaos experiment
  ALERT  // created by Alertmanager webhook
}
